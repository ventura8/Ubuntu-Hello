# Co-Maintainer: Raymo111 <hi@raymond.li>
# Contributor: Kelley McChesney <kelley@kelleymcchesney.us>

pkgname=ubuntu-hello
pkgver=1.0.0
pkgrel=1
pkgdesc="Windows Hello for Linux"
arch=('x86_64')
url="https://github.com/ventura8/ubuntu-hello"
license=('MIT')
depends=(
	'opencv'
	'hdf5'
	'pam-python'
	'python3'
	'python-dlib'
	'python-numpy'
	'python-opencv'
)
makedepends=(
	'cmake'
	'pkgfile'
)
backup=('etc/ubuntu-hello/config.ini')
source=(
	"$pkgname-$pkgver.tar.gz::https://github.com/ventura8/ubuntu-hello/archive/v${pkgver}.tar.gz"
	"https://github.com/davisking/dlib-models/raw/master/dlib_face_recognition_resnet_model_v1.dat.bz2"
	"https://github.com/davisking/dlib-models/raw/master/mmod_human_face_detector.dat.bz2"
	"https://github.com/davisking/dlib-models/raw/master/shape_predictor_5_face_landmarks.dat.bz2"
)
sha256sums=('f3f48599f78fd82b049539fcfc34de25c9435cad732697bdda94e85352964794'
            'abb1f61041e434465855ce81c2bd546e830d28bcbed8d27ffbe5bb408b11553a'
            'db9e9e40f092c118d5eb3e643935b216838170793559515541c56a2b50d9fc84'
            '6e787bbebf5c9efdb793f6cd1f023230c4413306605f24f299f12869f95aa472')

package() {
	# Installing the proper license files and the rest of ubuntu-hello
	cd ubuntu-hello-$pkgver
	install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
	mkdir -p "$pkgdir/usr/etc/ubuntu-hello"
	mkdir -p "$pkgdir/etc/ubuntu-hello"
	cp -r src/* "$pkgdir/usr/etc/ubuntu-hello"
	cp -r src/config.ini "$pkgdir/etc/ubuntu-hello"
	cp "${srcdir}/dlib_face_recognition_resnet_model_v1.dat" "$pkgdir/usr/etc/ubuntu-hello/dlib-data/"
	cp "${srcdir}/mmod_human_face_detector.dat" "$pkgdir/usr/etc/ubuntu-hello/dlib-data/"
	cp "${srcdir}/shape_predictor_5_face_landmarks.dat" "$pkgdir/usr/etc/ubuntu-hello/dlib-data/"
	chmod 600 -R "$pkgdir/usr/etc/ubuntu-hello"
	mkdir -p "$pkgdir/usr/bin"
	ln -s /etc/ubuntu-hello/cli.py "$pkgdir/usr/bin/ubuntu-hello"
	chmod +x "$pkgdir/etc/ubuntu-hello/cli.py"
	mkdir -p "$pkgdir/usr/share/bash-completion/completions"
	cp autocomplete/ubuntu-hello "$pkgdir/usr/share/bash-completion/completions/ubuntu-hello"
}
