#!/usr/bin/python3
# Executed on deinstallation
# Completely remove ubuntu-hello from the system

# Import required modules
import subprocess
import sys
import os
from shutil import rmtree

# Only run when we actually want to remove
if "remove" not in sys.argv and "purge" not in sys.argv:
	sys.exit(0)

# Don't try running this if it's already gone
if not os.path.exists("/lib/security/ubuntu-hello/cli"):
	sys.exit(0)

# Remove files and symlinks
try:
	os.unlink("/usr/local/bin/ubuntu-hello")
except Exception:
	print("Can't remove executable")
try:
	os.unlink("/usr/share/bash-completion/completions/ubuntu-hello")
except Exception:
	print("Can't remove autocompletion script")

# Refresh and remove ubuntu-hello from pam-config
try:
	subprocess.call(["pam-auth-update --package"], shell=True)
	subprocess.call(["rm /usr/share/pam-configs/ubuntu-hello"], shell=True)
	subprocess.call(["pam-auth-update --package"], shell=True)
except Exception:
	print("Can't remove pam module")

# Clean up Polkit systemd override
try:
	override_file = "/etc/systemd/system/polkit-agent-helper@.service.d/override.conf"
	if os.path.exists(override_file):
		os.unlink(override_file)
	override_dir = "/etc/systemd/system/polkit-agent-helper@.service.d"
	if os.path.exists(override_dir):
		os.rmdir(override_dir)
	subprocess.call(["systemctl", "daemon-reload"])
except Exception as e:
	print("Can't remove Polkit systemd helper override")

# Clean up stored keyring passwords
try:
	if os.path.exists("/etc/ubuntu-hello/keyring-keys"):
		rmtree("/etc/ubuntu-hello/keyring-keys")
except Exception:
	pass

# Remove full installation folder, just to be sure
try:
	rmtree("/lib/security/ubuntu-hello")
except Exception:
	# This error is normal
	pass

# Remove dlib
subprocess.call(["pip3", "uninstall", "dlib", "-y", "--no-cache-dir"])
