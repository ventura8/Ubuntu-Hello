#!/bin/bash
set -e

case "$1" in
    configure)
        # Try to run the GUI as the non-root user who ran sudo/apt (or fallback to active GUI user)
        REAL_USER="${SUDO_USER:-$USER}"

        # If REAL_USER is root, try to find the logged in desktop user
        if [ "$REAL_USER" = "root" ]; then
            REAL_USER=$(loginctl list-sessions | grep -v 'SESSION' | awk '{print $3}' | grep -v 'root' | head -n 1)
        fi

        # Only launch on fresh installation, not on upgrade
        if [ -z "$2" ]; then
            if [ -n "$REAL_USER" ] && [ "$REAL_USER" != "root" ]; then
                USER_HOME=$(eval echo "~$REAL_USER")
                XAUTHORITY_PATH="$USER_HOME/.Xauthority"
                
                if [ -f "$XAUTHORITY_PATH" ]; then
                    export XAUTHORITY="$XAUTHORITY_PATH"
                fi
                
                # Run the GUI in the background as the active GUI user on the current display
                (
                    export DISPLAY=:0
                    sudo -u "$REAL_USER" ubuntu-hello-gtk &
                ) 2>/dev/null || (
                    export DISPLAY=:1
                    sudo -u "$REAL_USER" ubuntu-hello-gtk &
                ) 2>/dev/null || true
            else
                # Fallback/last resort
                ubuntu-hello-gtk &
            fi
        fi
        ;;
esac

#DEBHELPER#

exit 0
